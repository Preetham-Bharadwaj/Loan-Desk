# ─────────────────────────────────────────────
# Loan Desk — Root .gitignore
# ─────────────────────────────────────────────

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
dist-ssr/
build/
.next/
out/
coverage/

# Environment & Secrets — NEVER commit these
.env
.env.*
!.env.example

# IDE / Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Cache
.cache/
.parcel-cache/
.eslintcache
.oxlintcache

# Vite
*.local
vite.svg

# TypeScript
*.tsbuildinfo

# Supabase
.supabase/

# Temporary
tmp/
temp/

# Generated files
*.pdf
generated/

# Test outputs
test-results/
playwright-report/
