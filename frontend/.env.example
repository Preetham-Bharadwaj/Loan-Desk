# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy this file to .env and fill in your Supabase project values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (found in: Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon / Publishable key (safe to expose in frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Demo accounts feature toggle (set to false to disable)
VITE_DEMO_ACCOUNTS_ENABLED=true

# Shared password for demo accounts (change before deploying)
VITE_DEMO_SHARED_PASSWORD=your_demo_password_here

# Backend API base URL (update for production deployment)
VITE_API_URL=http://localhost:5000/api
