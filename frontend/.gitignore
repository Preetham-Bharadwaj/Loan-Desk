# ─────────────────────────────────────────────
# Frontend .gitignore
# ─────────────────────────────────────────────

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
dist-ssr/
build/
coverage/

# Environment & Secrets — NEVER commit these
.env
.env.*
!.env.example

# IDE / Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Cache
.cache/
.eslintcache
.oxlintcache
*.local

# Vite
vite.svg

# TypeScript
*.tsbuildinfo

# Temporary
tmp/
temp/
