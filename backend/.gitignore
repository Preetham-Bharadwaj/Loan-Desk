# ─────────────────────────────────────────────
# Backend .gitignore
# ─────────────────────────────────────────────

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment & Secrets — NEVER commit these
.env
.env.*
!.env.example

# Build outputs
dist/
build/
coverage/

# IDE / Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Cache
.cache/

# Temporary
tmp/
temp/

# Generated PDFs / documents
*.pdf
generated/
uploads/
