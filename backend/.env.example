# ─────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (found in: Supabase Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role key — KEEP THIS SECRET, server-side only
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase Anon key (for auth operations)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# JWT secret for signing auth tokens — use a strong random string in production
JWT_SECRET=your_jwt_secret_here

# Port for the Express API server (default: 5000)
PORT=5000

# Frontend URL for CORS whitelist (e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173
